# Second Brain — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ============================================================
# REQUIRED — Bot won't start without these
# ============================================================

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=

# Your Telegram user ID (bot only responds to this user)
# Get it by messaging @userinfobot
TELEGRAM_USER_ID=

# ============================================================
# CLAUDE — Choose one authentication method
# ============================================================

# Option A: API key (recommended for VPS)
ANTHROPIC_API_KEY=

# Option B: OAuth (if using claude login)
# Leave ANTHROPIC_API_KEY blank and run: claude login

# Path to claude CLI (usually just "claude" if in PATH)
CLAUDE_PATH=claude

# ============================================================
# CODEX — Optional fallback orchestrator
# ============================================================

# OpenAI API key for Codex CLI (also accepts OPENAI_API_KEY)
# CODEX_API_KEY=

# Path to codex CLI (set automatically by install.sh --with-codex)
# CODEX_PATH=codex

# ============================================================
# LLM SERVICES — Stateless inference (multimodal, image gen)
# ============================================================

# Gemini API key — multimodal input (images, PDFs, voice) + image generation
# Get key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Gemini model for text/multimodal queries (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter API key — DeepSeek, GLM, and other models via unified API
# Get key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# ============================================================
# SESSION MANAGEMENT
# ============================================================

# Reset session after N queries (default: 50)
MAX_QUERIES=50

# Reset session after N hours (default: 8)
MAX_HOURS=8

# ============================================================
# TELEGRAM TOPICS (optional — for domain routing)
# ============================================================

# Group chat ID (starts with -100)
# GROUP_CHAT_ID=-100xxxxxxxxxx

# Topic IDs (get from bot logs after creating topics)
# TOPIC_GENERAL=1
# TOPIC_HEALTH=2
# TOPIC_WORK=3
# TOPIC_PERSONAL=4
# TOPIC_FINANCE=5

# ============================================================
# ADMIN PANEL (optional)
# ============================================================

# Secret token for admin panel access
# Generate with: openssl rand -hex 32
# ADMIN_TOKEN=

# Admin panel port (default: 8080)
# ADMIN_PORT=8080

# VPS base URL for OAuth callbacks
# VPS_BASE_URL=https://your-vps.example.com

# ============================================================
# INTEGRATIONS — Data Sources (optional)
# ============================================================

# Oura Ring (sleep, readiness, HRV)
# Get token: https://cloud.ouraring.com/personal-access-tokens
# OURA_TOKEN=

# Google (Gmail, Calendar, Drive) — OAuth2
# Create credentials: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# Zoom (cloud recordings) — Server-to-Server OAuth
# Create app: https://marketplace.zoom.us/develop/create
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# ============================================================
# VOICE NOTES (optional — requires Whisper)
# ============================================================

# Whisper model size: tiny, base, small, medium, large
# WHISPER_MODEL=base

# ============================================================
# SYNCTHING (optional — for local folder sync)
# ============================================================

# Syncthing API key (from Syncthing web UI → Actions → Settings → API Key)
# SYNCTHING_API_KEY=

# Syncthing address (default: localhost:8384)
# SYNCTHING_ADDRESS=localhost:8384
